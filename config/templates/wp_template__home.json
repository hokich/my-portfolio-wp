ont-weight:700;text-transform:uppercase\"><a href=\"#\">/</a> Der Anfang</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"style\":{\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|background\"}}},\"typography\":{\"fontSize\":\"18px\"}},\"textColor\":\"background\"} -->\n<p class=\"has-background-color has-text-color has-link-color\" style=\"font-size:18px\">2017 begann ich mich intensiv mit Webentwicklung zu beschäftigen.<br><br>Mit viel Neugier, Eigeninitiative und zahlreichen praktischen Projekten legte ich die Grundlage für meinen beruflichen Weg.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"85px\"}},\"layout\":{\"type\":\"constrained\",\"wideSize\":\"560px\",\"justifyContent\":\"left\"}} -->\n<div class=\"wp-block-group\"><!-- wp:image {\"id\":30,\"width\":\"560px\",\"aspectRatio\":\"4/3\",\"scale\":\"cover\",\"sizeSlug\":\"large\",\"linkDestination\":\"none\",\"style\":{\"border\":{\"radius\":\"10px\"}}} -->\n<figure class=\"wp-block-image size-large is-resized has-custom-border\"><img src=\"http://localhost:8080/wp-content/uploads/2026/03/IMG_8314-2-1-1024x768.jpg\" alt=\"\" class=\"wp-image-30\" style=\"border-radius:10px;aspect-ratio:4/3;object-fit:cover;width:560px\"/></figure>\n<!-- /wp:image --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"0\"},\"padding\":{\"top\":\"220px\",\"bottom\":\"120px\"}}},\"backgroundColor\":\"primary\",\"layout\":{\"type\":\"constrained\",\"wideSize\":\"100%\",\"contentSize\":\"100%\"}} -->\n<div class=\"wp-block-group has-primary-background-color has-background\" style=\"margin-top:0;margin-bottom:0;padding-top:220px;padding-bottom:120px\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"70px\"}},\"layout\":{\"type\":\"constrained\",\"wideSize\":\"100%\"}} -->\n<div class=\"